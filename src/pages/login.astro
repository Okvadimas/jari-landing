---
import AuthLayout from '../layouts/AuthLayout.astro';
---

<AuthLayout title="Login | Jaripos">
    <div class="w-full max-w-md bg-white rounded-2xl shadow-xl border border-slate-100 p-8 m-4">
        
        <div class="text-center mb-8">
            <a href="/" class="inline-flex items-center justify-center w-12 h-12 bg-gradient-to-br from-brand-500 to-brand-600 rounded-xl text-white font-bold text-3xl shadow-lg shadow-brand-500/30 mb-4 transition-transform hover:scale-105">
                J
            </a>
            <h1 class="text-2xl font-bold text-slate-900">Selamat Datang Kembali</h1>
            <p class="text-slate-500 text-sm mt-2">Masuk untuk mengelola bisnis Anda.</p>
        </div>

        <form>
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Email</label>
                    <input type="email" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-all" placeholder="nama@email.com">
                </div>
                <div>
                    <div class="flex justify-between items-center mb-1">
                        <label class="block text-sm font-medium text-slate-700">Password</label>
                        <a href="#" class="text-xs text-brand-600 hover:text-brand-700 font-medium">Lupa Password?</a>
                    </div>
                    <input type="password" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-all" placeholder="••••••••">
                </div>
                
                <div class="flex items-center">
                    <input type="checkbox" id="remember" class="w-4 h-4 text-brand-600 border-slate-300 rounded focus:ring-brand-500">
                    <label for="remember" class="ml-2 block text-sm text-slate-600">Ingat saya</label>
                </div>

                <button type="submit" class="w-full bg-brand-600 text-white font-bold rounded-xl py-3 px-4 hover:bg-brand-700 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 transition-all shadow-lg shadow-brand-500/30 mt-6">
                    Masuk
                </button>
            </div>
        </form>

        <p class="text-center text-sm text-slate-600 mt-8">
            Belum punya akun? <a href="/register" class="font-bold text-brand-600 hover:text-brand-700">Daftar sekarang gratis</a>
        </p>
    </div>
</AuthLayout>
