---
import AuthLayout from '../layouts/AuthLayout.astro';
---

<AuthLayout title="Register | Jaripos">
    <div class="w-full max-w-md bg-white rounded-2xl shadow-xl border border-slate-100 p-8 m-4">
        
        <div class="text-center mb-8">
            <a href="/" class="inline-flex items-center justify-center w-12 h-12 bg-gradient-to-br from-brand-500 to-brand-600 rounded-xl text-white font-bold text-3xl shadow-lg shadow-brand-500/30 mb-4 transition-transform hover:scale-105">
                J
            </a>
            <h1 class="text-2xl font-bold text-slate-900">Mulai Bisnis Anda</h1>
            <p class="text-slate-500 text-sm mt-2">Buat akun Jaripos gratis sekarang juga.</p>
        </div>

        <!-- React form component bisa dipanggil di sini nantinya -->
        <!-- <RegisterForm client:load /> -->
        
        <form>
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Nama Lengkap</label>
                    <input type="text" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-all" placeholder="Budi Santoso">
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Email</label>
                    <input type="email" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-all" placeholder="nama@email.com">
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Password</label>
                    <input type="password" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-all" placeholder="Min. 8 karakter">
                </div>

                <button type="submit" class="w-full bg-brand-600 text-white font-bold rounded-xl py-3 px-4 hover:bg-brand-700 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 transition-all shadow-lg shadow-brand-500/30 mt-6">
                    Mulai Sekarang
                </button>
            </div>
        </form>

        <p class="text-center text-sm text-slate-600 mt-8">
            Sudah punya akun? <a href="/login" class="font-bold text-brand-600 hover:text-brand-700">Masuk di sini</a>
        </p>
    </div>
</AuthLayout>
