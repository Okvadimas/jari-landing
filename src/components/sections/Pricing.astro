---
---
<section id="pricing" class="py-24 bg-white relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] [background-size:16px_16px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_70%,transparent_100%)] opacity-30"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center mb-16" data-aos="fade-up">
            <span class="text-brand-600 font-bold tracking-wider uppercase text-sm bg-brand-50 px-3 py-1 rounded-full border border-brand-100">Rencana Harga</span>
            <h2 class="text-3xl md:text-5xl font-black text-slate-900 mt-4 mb-4 tracking-tight">Investasi Receh, Untung Gede</h2>
            <p class="text-slate-500 text-md md:text-xl max-w-2xl mx-auto">Semua pemilik bisnis berhak sukses. Mulai perjalanan Anda tanpa biaya.</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 max-w-6xl mx-auto items-stretch">
            
            <!-- LEFT: Paket Jempol (Premium - Recommended Entry via Trial) -->
            <div data-aos="fade-right" class="w-full lg:col-span-7 bg-slate-900 rounded-3xl md:rounded-[2.5rem] p-8 md:p-10 border border-slate-800 shadow-[0_20px_50px_rgba(6,182,212,0.06)] hover:border-cyan-500/30 hover:shadow-[0_20px_60px_rgba(6,182,212,0.14)] transition-all duration-500 flex flex-col justify-between relative group overflow-hidden">
                <!-- Glowing Decoration -->
                <div class="absolute -top-24 -left-24 w-64 h-64 bg-cyan-500/20 rounded-full blur-3xl group-hover:bg-cyan-500/35 transition-all duration-700"></div>
                
                <div class="relative z-10">
                    <div class="flex justify-between items-center mb-6">
                        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-gradient-to-r from-amber-400 to-orange-500 text-slate-950 text-xs font-black uppercase tracking-wider border border-amber-300/10">
                            <span class="text-base leading-none">🔥</span> Coba Gratis 14 Hari (Akses Penuh)
                        </div>
                    </div>
                    
                    <h3 class="text-3xl font-black text-white mb-2">Paket Jempol</h3>
                    <p class="text-slate-400 text-sm mb-6">Akses semua fitur kasir premium tanpa batas: kelola multi-kasir, kontrol stok otomatis, laporan laba-rugi lengkap, dan asisten AI pintar.</p>
                    
                    <!-- Main Uji Coba Gratis Rp 0 Display -->
                    <div class="flex flex-col mb-8 bg-slate-800/40 p-5 rounded-2xl border border-slate-800 relative overflow-hidden group-hover:border-cyan-brand/30 transition-all duration-300">
                        <div class="absolute inset-0 bg-gradient-to-r from-cyan-500/5 to-transparent opacity-50"></div>
                        <div class="relative z-10 flex items-baseline justify-between flex-wrap gap-2">
                            <div class="flex items-baseline">
                                <span class="text-5xl md:text-6xl font-black text-white tracking-tight">Rp 0</span>
                                <span class="text-slate-400 ml-2 text-xs font-semibold">/ 14 Hari Pertama</span>
                            </div>
                            <span class="text-[10px] font-black text-cyan-brand bg-cyan-brand/10 border border-cyan-brand/20 px-2 py-1 rounded-md uppercase tracking-wider">
                                Tanpa Komitmen
                            </span>
                        </div>
                        <p class="relative z-10 text-slate-400 text-xs mt-3 flex items-center gap-1.5">
                            <svg class="w-4 h-4 text-cyan-brand flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            <span>Nikmati semua fitur premium, selanjutnya mulai <strong class="text-white">Rp 30k/bulan</strong></span>
                        </p>
                    </div>

                    <div class="border-t border-slate-800 pt-6 mb-8">
                        <p class="text-xs font-bold text-cyan-brand uppercase tracking-widest mb-4">Semua Fitur Kelingking PLUS:</p>
                        <ul class="space-y-4">
                            <li class="flex items-start gap-3 text-slate-300">
                                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-cyan-brand/10 flex items-center justify-center mt-0.5">
                                    <svg class="w-3 h-3 text-cyan-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                </div>
                                <span class="text-sm font-bold text-white">Transaksi Harian Tanpa Batas</span>
                            </li>
                            <li class="flex items-start gap-3 text-slate-300">
                                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-cyan-brand/10 flex items-center justify-center mt-0.5">
                                    <svg class="w-3 h-3 text-cyan-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                </div>
                                <span class="text-sm font-bold text-white">Kelola Multi-Kasir & Role Karyawan</span>
                            </li>
                            <li class="flex items-start gap-3 text-slate-300">
                                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-cyan-brand/10 flex items-center justify-center mt-0.5">
                                    <svg class="w-3 h-3 text-cyan-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                </div>
                                <span class="text-sm font-bold text-white">Jari AI & Rekomendasi Stok Pintar</span>
                            </li>
                            <li class="flex items-start gap-3 text-slate-300">
                                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-cyan-brand/10 flex items-center justify-center mt-0.5">
                                    <svg class="w-3 h-3 text-cyan-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                </div>
                                <span class="text-sm">Manajemen Stok & Inventori Lanjutan</span>
                            </li>
                            <li class="flex items-start gap-3 text-slate-300">
                                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-cyan-brand/10 flex items-center justify-center mt-0.5">
                                    <svg class="w-3 h-3 text-cyan-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                </div>
                                <span class="text-sm">Cetak Struk Bluetooth HP</span>
                            </li>
                            <li class="flex items-start gap-3 text-slate-300">
                                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-cyan-brand/10 flex items-center justify-center mt-0.5">
                                    <svg class="w-3 h-3 text-cyan-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                </div>
                                <span class="text-sm">Laporan Laba/Rugi & Analisis Finansial Real-Time</span>
                            </li>
                        </ul>
                    </div>
                </div>

                <div class="mt-8">
                    <a href="https://app.jaripos.com/register" data-track="pricing-cta-jempol-trial" class="block w-full text-center px-6 py-5 rounded-2xl bg-cyan-brand text-white font-extrabold text-lg shadow-[0_0_30px_rgba(6,182,212,0.35)] hover:shadow-[0_0_40px_rgba(6,182,212,0.55)] hover:brightness-110 transform hover:scale-[1.02] transition-all duration-300">
                        Mulai Uji Coba Gratis 14 Hari
                    </a>
                    
                    <p class="mt-4 text-center text-slate-500 text-xs leading-relaxed">
                        Akun otomatis kembali ke Paket Kelingking (Free) yang gratis selamanya setelah 14 hari jika Anda memilih untuk tidak upgrade. Tanpa perlu kartu kredit.
                    </p>
                </div>
            </div>

            <!-- RIGHT: Paket Kelingking (Free Forever) -->
            <div data-aos="fade-left" class="w-full lg:col-span-5 bg-slate-50 rounded-3xl md:rounded-[2.5rem] p-8 md:p-10 border border-slate-200 shadow-md flex flex-col justify-between relative group opacity-90 hover:opacity-100 transition-all duration-300">
                <div class="relative z-10">
                    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-200 text-slate-600 text-[10px] font-bold mb-6 uppercase tracking-wider">
                        Gratis Selamanya
                    </div>
                    
                    <h3 class="text-3xl font-black text-slate-900 mb-2">Paket Kelingking</h3>
                    <p class="text-slate-500 text-sm mb-6">Cocok untuk usaha pemula atau mikro yang ingin mendigitalisasikan transaksi harian secara sederhana dengan beberapa batasan.</p>
                    
                    <div class="flex items-baseline mb-8">
                        <span class="text-4xl md:text-5xl font-black text-slate-900">Rp 0</span>
                        <span class="text-slate-500 ml-2 text-sm font-medium">/ Selamanya</span>
                    </div>

                    <div class="border-t border-slate-200 pt-6 mb-8">
                        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4">Fitur & Batasan Paket:</p>
                        <ul class="space-y-4">
                            <li class="flex items-start gap-3 text-slate-600">
                                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-amber-50 border border-amber-200 flex items-center justify-center mt-0.5">
                                    <svg class="w-3 h-3 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                                </div>
                                <span class="text-sm">Maksimal <strong>100 transaksi</strong> / bulan</span>
                            </li>
                            <li class="flex items-start gap-3 text-slate-600">
                                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-amber-50 border border-amber-200 flex items-center justify-center mt-0.5">
                                    <svg class="w-3 h-3 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                                </div>
                                <span class="text-sm">Maksimal <strong>50 item produk</strong> di inventori</span>
                            </li>
                            <li class="flex items-start gap-3 text-slate-600">
                                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-amber-50 border border-amber-200 flex items-center justify-center mt-0.5">
                                    <svg class="w-3 h-3 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                                </div>
                                <span class="text-sm">Hanya <strong>1 user kasir utama</strong> (Tanpa staf)</span>
                            </li>
                            <li class="flex items-start gap-3 text-slate-600">
                                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-slate-200 flex items-center justify-center mt-0.5">
                                    <svg class="w-3 h-3 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                </div>
                                <span class="text-sm">Hanya laporan harian sederhana</span>
                            </li>
                            <li class="flex items-start gap-3 text-slate-400 line-through">
                                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-slate-100 flex items-center justify-center mt-0.5">
                                    <svg class="w-3 h-3 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
                                </div>
                                <span class="text-sm">Tanpa Jari AI & Rekomendasi Stok</span>
                            </li>
                            <li class="flex items-start gap-3 text-slate-600">
                                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-slate-200 flex items-center justify-center mt-0.5">
                                    <svg class="w-3 h-3 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                </div>
                                <span class="text-sm">Multi-Platform (Web & HP)</span>
                            </li>
                            <li class="flex items-start gap-3 text-slate-600">
                                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-slate-200 flex items-center justify-center mt-0.5">
                                    <svg class="w-3 h-3 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                </div>
                                <span class="text-sm">Dukungan Komunitas</span>
                            </li>
                        </ul>
                    </div>
                </div>

                <div class="mt-8">
                    <a href="https://app.jaripos.com/register" data-track="pricing-cta-free" class="block w-full text-center px-6 py-4 rounded-2xl bg-white border border-slate-200 text-slate-500 font-bold hover:bg-slate-100 hover:text-slate-700 transition duration-300 text-sm">
                        Mulai dengan Batasan Gratis
                    </a>
                </div>
            </div>

        </div>
    </div>
</section>
